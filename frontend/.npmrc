# Habitta React — npm security configuration
# This file is read by both npm and pnpm.

# Fail the install if any dependency has a vulnerability at this level or higher.
# Options: low | moderate | high | critical
audit-level=moderate

# Don't show funding messages (keeps audit output clean)
fund=false

# Lock engine versions — prevents accidental installs on unsupported Node
engine-strict=false

# Prefer exact versions when saving new dependencies (more reproducible builds)
save-exact=false
