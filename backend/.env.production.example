# =============================================================================
# Habitta — PRODUCTION environment variables (Railway)
# Copy these to Railway → your service → Variables tab.
# Lines starting with # are comments — do NOT paste them into Railway.
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Habitta
APP_ENV=production
APP_DEBUG=false

# Run locally first: php artisan key:generate --show
# Then paste the output here.
APP_KEY=base64:REPLACE_WITH_GENERATED_KEY

# Replace with your actual Railway URL after first deploy
APP_URL=https://habitta-backend.up.railway.app

# Replace with your Vercel URL after deploying React
FRONTEND_URL=https://habitta.vercel.app

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_MX
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# ── Logging ───────────────────────────────────────────────────────────────────
# stderr = Railway shows logs in its dashboard
LOG_CHANNEL=stderr
LOG_LEVEL=error

# ── Database (PostgreSQL via Railway add-on) ──────────────────────────────────
# In Railway dashboard: set these using "Reference Variable" to link
# automatically to your Postgres service:
#
#   DB_HOST     → ${{Postgres.PGHOST}}
#   DB_PORT     → ${{Postgres.PGPORT}}
#   DB_DATABASE → ${{Postgres.PGDATABASE}}
#   DB_USERNAME → ${{Postgres.PGUSER}}
#   DB_PASSWORD → ${{Postgres.PGPASSWORD}}
#
# OR: paste the values from the Postgres service's "Connect" tab directly.

DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=railway
DB_USERNAME=postgres
DB_PASSWORD=

# ── Session / Cache / Queue ───────────────────────────────────────────────────
# All use the database so no Redis is needed.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ── Mail (leave as log for academic demo) ─────────────────────────────────────
MAIL_MAILER=log

# ── AI Feature ────────────────────────────────────────────────────────────────
# Optional — GD fallback works without a key.
# Get a free key at: https://huggingface.co/settings/tokens
HF_API_KEY=hf_YOUR_KEY_HERE
